{
  "name": "blog",
  "description": "egineer blog of t-yng",
  "version": "2.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "export": "next export",
    "dev": "rm -fr .next && next dev",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json}\"",
    "start": "next start",
    "bundle-analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:diff": "bun run test --changed=origin/main",
    "test:coverage": "bun run test --coverage",
    "test:e2e": "playwright test",
    "test:update-snapshots": "bun run test:e2e --update-snapshots",
    "lint:all": "eslint src && bun run lint:html",
    "lint:html": "markuplint -p \"./src/**/*.tsx\"",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc",
    "panda:codegen": "panda codegen --clean -c src/styles/panda.config.ts",
    "prepare": "husky && bun run panda:codegen"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.tsx": [
      "markuplint -p"
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "4.2.1",
    "gray-matter": "4.0.3",
    "js-cookie": "^3.0.7",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.9.0",
    "@markuplint/jsx-parser": "4.18.3",
    "@markuplint/react-spec": "4.18.0",
    "@next/bundle-analyzer": "16.2.9",
    "@pandacss/dev": "1.11.3",
    "@playwright/test": "1.61.1",
    "@shikijs/markdown-it": "4.3.0",
    "@swc/core": "^1.15.33",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/cpx": "1.5.6",
    "@types/gtag.js": "0.0.20",
    "@types/js-cookie": "^3.0.6",
    "@types/markdown-it": "14.1.2",
    "@types/react": "^19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "cheerio": "1.2.0",
    "cpx": "1.5.0",
    "eslint": "10.6.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "9.1.7",
    "hygen": "6.2.11",
    "identity-obj-proxy": "3.0.0",
    "image-size": "^2.0.2",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "markdown-it": "14.2.0",
    "markuplint": "4.18.3",
    "prettier": "3.8.5",
    "ts-mockito": "2.6.1",
    "typescript": "6.0.3",
    "url-join": "5.0.0",
    "vitest": "4.1.9"
  },
  "resolutions": {
    "estree-walker": "npm:@benpsnyder/estree-walker@3.0.3"
  }
}
